package com.example.alarm.Fragment;


import android.os.Bundle;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.TextView;
import android.widget.Toast;

import androidx.annotation.NonNull;
import androidx.annotation.Nullable;
import androidx.fragment.app.Fragment;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.example.alarm.R;
import com.example.alarm.Adapter.AlarmAdapter;
import com.example.alarm.DAO.AlarmDao;
import com.example.alarm.Model.Alarm;
import com.example.alarm.Fragment.CrudFragment;

import java.util.List;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;

public class AlarmFragment extends Fragment {

    public static final String REQUEST_ALARM_CHANGED =
            "request_alarm_changed";

    public static final String RESULT_ACTION =
            "result_action";

    public static final String ACTION_SAVED =
            "action_saved";

    public static final String ACTION_DELETED =
            "action_deleted";

    private RecyclerView rvAlarms;
    private TextView tvAddNew;

    private AlarmAdapter alarmAdapter;
    private AlarmDao alarmDao;

    private CrudFragment crudFragment;

    private final ExecutorService databaseExecutor =
            Executors.newSingleThreadExecutor();

    public AlarmFragment() {
        super(R.layout.fragment_alarm);
    }

    @Override
    public void onViewCreated(
            @NonNull View view,
            @Nullable Bundle savedInstanceState
    ) {
        super.onViewCreated(view, savedInstanceState);

        rvAlarms = view.findViewById(R.id.rv_alarms);
        tvAddNew = view.findViewById(R.id.tv_add_new);

        alarmDao = new AlarmDao(requireContext());

        setupRecyclerView();
        setupClickListeners();
        setupCrudResultListener();

        alarmDao.getAllAlarms();
    }

    private void setupRecyclerView() {
        alarmAdapter = new AlarmAdapter(
                // Nhấn vào một alarm để sửa
                alarm -> openCrudFragment(alarm.getId()),

                // Bật hoặc tắt alarm
                (alarm) -> alarmDao.updateAlarm(alarm)
        );

        rvAlarms.setLayoutManager(
                new LinearLayoutManager(requireContext())
        );

        rvAlarms.setAdapter(alarmAdapter);
        rvAlarms.setHasFixedSize(true);
    }

    private void setupClickListeners() {
        tvAddNew.setOnClickListener(view -> {
            // -1 nghĩa là thêm alarm mới
            openCrudFragment(-1);
        });
    }

    private void setupCrudResultListener() {
        getParentFragmentManager()
                .setFragmentResultListener(
                        REQUEST_ALARM_CHANGED,
                        getViewLifecycleOwner(),
                        (requestKey, bundle) -> {
                            String action = bundle.getString(
                                    RESULT_ACTION,
                                    ACTION_SAVED
                            );

                            // CrudFragment đã sửa DB xong,
                            // AlarmFragment chỉ cần tải lại danh sách.
                            alarmDao.getAllAlarms();

                            if (ACTION_DELETED.equals(action)) {
                                showToast("Đã xóa báo thức");
                            } else {
                                showToast("Đã lưu báo thức");
                            }
                        }
                );
    }



    private void openCrudFragment(int alarmId) {
        CrudFragment crudFragment =
                CrudFragment.newInstance(alarmId);

        getParentFragmentManager()
                .beginTransaction()
                .replace(
                        R.id.fragment_container,
                        crudFragment
                )
                .addToBackStack("crud_alarm")
                .commit();
    }

    private void showToast(String message) {
        if (!isAdded()) {
            return;
        }

        Toast.makeText(
                requireContext(),
                message,
                Toast.LENGTH_SHORT
        ).show();
    }

    @Override
    public void onResume() {
        super.onResume();

        /*
         * Có thể tải lại để đảm bảo danh sách luôn mới
         * khi quay lại AlarmFragment.
         */
        alarmDao.getAllAlarms();
    }

    @Override
    public void onDestroy() {
        super.onDestroy();
        databaseExecutor.shutdown();
    }
}
